# ============================================================================
# Firmware — DO NOT COMMIT
#
# The FX2 / FPGA firmware and waveform LUTs are copyrighted by Pico Technology
# Ltd. Reverse-engineering the protocol is legal in most jurisdictions, but
# redistributing the firmware blobs is not. Each user must extract these from
# their own device — see docs/firmware-extraction.md.
# ============================================================================
driver/picoscope2204a_fw.h
driver/picoscope2204a_stream_lut.h
driver/firmware/*.bin
driver/firmware/*.txt
!driver/firmware/.gitkeep
**/fx2_firmware*.bin
**/fx2_firmware*.txt
**/fpga_firmware*.bin
**/ps2000_firmware*.bin
**/ep06_*.bin

# ============================================================================
# USB captures — may embed firmware / device serials
# ============================================================================
*.pcap
*.pcapng
usb_trace.log
usb_strace.log
sdk_strace.log
trace_*.log
# SDK-stream-trace raw captures (LD_PRELOAD output of the proprietary SDK)
tools/sdk-stream-trace/*.log
tools/sdk-stream-trace/*.stdout
tools/sdk-stream-trace/sdk_param_phase_table.txt

# ============================================================================
# SDK-stream-trace ELF binaries (rebuilt locally from the *.c sources)
# ============================================================================
tools/sdk-stream-trace/experiments
tools/sdk-stream-trace/sdk_autostop_matrix
tools/sdk-stream-trace/sdk_open_only
tools/sdk-stream-trace/sdk_stream_trace
tools/sdk-stream-trace/sdk_stream_param
tools/sdk-stream-trace/our_stream_trace

